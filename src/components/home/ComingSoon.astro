---
/**
 * Coming Soon Component
 *
 * Teaser section for upcoming products with email signup.
 * Creates anticipation through visual design and limited information.
 *
 * Features:
 * - Eye-catching gradient background
 * - Animated elements for visual interest
 * - Email capture form
 * - Fully configurable
 */

import Container from '@components/ui/Container.astro';
import Button from '@components/ui/Button.astro';
import Badge from '@components/ui/Badge.astro';
import Input from '@components/ui/Input.astro';
import FadeIn from '@components/animations/FadeIn';

interface Props {
  /** Section ID */
  id?: string;
  /** Badge text */
  badge?: string;
  /** Product name */
  title?: string;
  /** Product description */
  description?: string;
  /** Email input placeholder */
  emailPlaceholder?: string;
  /** Submit button text */
  buttonText?: string;
  /** Form name for submission handling */
  formName?: string;
  /** Privacy note text */
  privacyNote?: string;
  /** Accent color variant */
  accentColor?: 'violet' | 'cyan' | 'orange';
}

const {
  id = 'coming-soon',
  badge = 'Coming 2025',
  title = 'AI Photo Editor',
  description = 'Professional-grade photo editing powered by cutting-edge AI. Transform your selfies and portraits with a single tap.',
  emailPlaceholder = 'Enter your email',
  buttonText = 'Notify Me',
  formName = 'coming-soon-signup',
  privacyNote = 'Be the first to know when we launch. No spam, ever.',
  accentColor = 'violet',
} = Astro.props;

// Color variants for the gradient
const colorVariants = {
  violet: {
    primary: 'from-violet-600/30 via-indigo-600/20',
    secondary: 'from-purple-500/20 to-pink-500/10',
    glow: 'bg-violet-500/30',
    radial: 'rgba(124, 58, 237, 0.4)',
  },
  cyan: {
    primary: 'from-cyan-600/30 via-blue-600/20',
    secondary: 'from-teal-500/20 to-cyan-500/10',
    glow: 'bg-cyan-500/30',
    radial: 'rgba(6, 182, 212, 0.4)',
  },
  orange: {
    primary: 'from-orange-600/30 via-red-600/20',
    secondary: 'from-amber-500/20 to-orange-500/10',
    glow: 'bg-orange-500/30',
    radial: 'rgba(249, 115, 22, 0.4)',
  },
};

const colors = colorVariants[accentColor];
---

<section id={id} class="section relative overflow-hidden" aria-labelledby="coming-soon-title">
  <Container size="narrow">
    <FadeIn client:visible>
      <div class="relative rounded-3xl overflow-hidden">
        <!-- Background layers -->
        <div class="absolute inset-0" aria-hidden="true">
          <!-- Base gradient -->
          <div class:list={[
            'absolute inset-0 bg-gradient-to-br to-transparent',
            colors.primary,
          ]}></div>

          <!-- Secondary gradient -->
          <div class:list={[
            'absolute inset-0 bg-gradient-to-tl',
            colors.secondary,
          ]}></div>

          <!-- Radial glow -->
          <div
            class="absolute top-0 right-0 w-[400px] h-[400px] rounded-full blur-[100px] opacity-60"
            style={`background: radial-gradient(circle, ${colors.radial}, transparent 70%);`}
          ></div>

          <!-- Animated orbs -->
          <div class="absolute top-1/4 left-1/4 w-32 h-32 rounded-full blur-[60px] animate-float-slow" style={`background: ${colors.radial};`}></div>
          <div class="absolute bottom-1/4 right-1/3 w-24 h-24 rounded-full blur-[50px] animate-float-slower" style={`background: ${colors.radial};`}></div>

          <!-- Grid pattern -->
          <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:32px_32px] opacity-50"></div>

          <!-- Noise texture overlay -->
          <div class="absolute inset-0 opacity-[0.015]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.8%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E');"></div>
        </div>

        <!-- Content -->
        <div class="relative p-8 md:p-12 lg:p-16">
          <div class="text-center max-w-lg mx-auto">
            <!-- Badge -->
            <Badge variant="accent" dot class="mb-6">
              {badge}
            </Badge>

            <!-- Title -->
            <h2 id="coming-soon-title" class="h2 mb-4">
              {title}
            </h2>

            <!-- Description -->
            <p class="lead mb-8">
              {description}
            </p>

            <!-- Preview image placeholder -->
            <div class="mb-8 relative">
              <div class="aspect-video rounded-2xl overflow-hidden bg-gradient-to-br from-white/5 to-white/[0.02] border border-white/10">
                <!-- Abstract preview visualization -->
                <div class="absolute inset-0 flex items-center justify-center">
                  <div class="relative">
                    <!-- Stylized AI icon -->
                    <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-white/10 to-white/5 border border-white/10 flex items-center justify-center">
                      <svg class="w-10 h-10 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                      </svg>
                    </div>
                    <!-- Decorative elements -->
                    <div class="absolute -top-2 -right-2 w-4 h-4 rounded-full bg-accent/50 animate-pulse"></div>
                    <div class="absolute -bottom-1 -left-1 w-3 h-3 rounded-full bg-cyan-500/50 animate-pulse" style="animation-delay: 0.5s;"></div>
                  </div>
                </div>

                <!-- Feature hints -->
                <div class="absolute bottom-4 left-4 right-4 flex justify-center gap-4">
                  <div class="px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-xs text-gray-400">
                    AI Enhancement
                  </div>
                  <div class="px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-xs text-gray-400 hidden sm:block">
                    One-Tap Editing
                  </div>
                  <div class="px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-xs text-gray-400 hidden md:block">
                    Pro Results
                  </div>
                </div>
              </div>
            </div>

            <!-- Email Signup Form -->
            <form
              name={formName}
              class="max-w-md mx-auto"
              method="POST"
              data-netlify="true"
            >
              <input type="hidden" name="form-name" value={formName} />

              <div class="flex gap-3">
                <div class="flex-1">
                  <Input
                    name="email"
                    type="email"
                    placeholder={emailPlaceholder}
                    required
                  />
                </div>
                <Button type="submit" variant="secondary">
                  {buttonText}
                </Button>
              </div>

              <p class="text-xs text-gray-500 mt-4">
                {privacyNote}
              </p>
            </form>
          </div>
        </div>

        <!-- Border glow effect -->
        <div class="absolute inset-0 rounded-3xl border border-white/10 pointer-events-none"></div>
      </div>
    </FadeIn>
  </Container>
</section>

<style>
  @keyframes float-slow {
    0%, 100% {
      transform: translate(0, 0) scale(1);
    }
    50% {
      transform: translate(20px, -20px) scale(1.1);
    }
  }

  @keyframes float-slower {
    0%, 100% {
      transform: translate(0, 0) scale(1);
    }
    50% {
      transform: translate(-15px, 15px) scale(0.9);
    }
  }

  .animate-float-slow {
    animation: float-slow 8s ease-in-out infinite;
  }

  .animate-float-slower {
    animation: float-slower 10s ease-in-out infinite;
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .animate-float-slow,
    .animate-float-slower {
      animation: none;
    }
  }
</style>

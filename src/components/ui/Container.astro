---
/**
 * Container Component
 *
 * Provides consistent max-width and padding for page sections.
 * Use this to wrap content that needs to be constrained.
 */

type ContainerSize = 'narrow' | 'default' | 'wide' | 'full';

interface Props {
  /** Container size variant */
  size?: ContainerSize;
  /** Additional CSS classes */
  class?: string;
  /** Center content horizontally */
  center?: boolean;
  /** HTML tag to render */
  as?: 'div' | 'section' | 'article' | 'main' | 'aside';
}

const {
  size = 'default',
  class: className = '',
  center = true,
  as: Tag = 'div',
} = Astro.props;

const sizeClasses: Record<ContainerSize, string> = {
  narrow: 'max-w-3xl',      // 768px - for text-heavy content
  default: 'max-w-6xl',     // 1152px - standard content
  wide: 'max-w-7xl',        // 1280px - for feature sections
  full: 'max-w-none',       // Full width
};
---

<Tag
  class:list={[
    'w-full px-6 md:px-8',
    sizeClasses[size as ContainerSize],
    center && 'mx-auto',
    className,
  ]}
>
  <slot />
</Tag>

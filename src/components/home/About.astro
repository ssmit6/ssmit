---
/**
 * About Section Component
 *
 * Company philosophy and values section.
 * Designed to build trust and communicate brand identity.
 *
 * Features:
 * - Compelling headline
 * - Philosophy paragraphs
 * - Location indicator
 * - Visual elements for interest
 */

import Container from '@components/ui/Container.astro';
import Badge from '@components/ui/Badge.astro';
import FadeIn from '@components/animations/FadeIn';
import { siteConfig } from '@lib/config';

interface Props {
  /** Section ID */
  id?: string;
  /** Badge text */
  badge?: string;
  /** Main headline */
  headline?: string;
  /** Philosophy paragraphs */
  paragraphs?: string[];
  /** Closing statement (emphasized) */
  closingStatement?: string;
  /** Show location */
  showLocation?: boolean;
  /** Show values list */
  showValues?: boolean;
}

const {
  id = 'about',
  badge = 'About Us',
  headline = "We're Not Just Another App Studio",
  paragraphs = [
    "We believe the best apps emerge from deep understanding — of the problem, the people, and the moment they'll reach for your product.",
    "Based in Sacramento, California, we combine thoughtful design with technical excellence to create mobile experiences that earn their place on your home screen.",
  ],
  closingStatement = "Cyclia is our first step. It won't be our last.",
  showLocation = true,
  showValues = true,
} = Astro.props;

// Company values
const values = [
  {
    icon: '💡',
    title: 'Innovation',
    description: 'Pushing boundaries with every project',
  },
  {
    icon: '✨',
    title: 'Quality',
    description: 'Obsessive attention to detail',
  },
  {
    icon: '🤝',
    title: 'Trust',
    description: 'Privacy and security by default',
  },
  {
    icon: '❤️',
    title: 'Care',
    description: 'Built for people, not metrics',
  },
];

const { address } = siteConfig;
const locationString = `${address.city}, ${address.state}`;
---

<section id={id} class="section relative overflow-hidden" aria-labelledby="about-title">
  <!-- Subtle background -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-gradient-to-b from-accent/5 to-transparent rounded-full blur-[100px]"></div>
  </div>

  <Container size="default" class="relative">
    <div class="max-w-4xl mx-auto">
      <!-- Header -->
      <div class="text-center mb-12 lg:mb-16">
        <FadeIn client:visible>
          <Badge variant="success" dot class="mb-4">{badge}</Badge>
        </FadeIn>

        <FadeIn client:visible delay={0.05}>
          <h2 id="about-title" class="h2 mb-6">{headline}</h2>
        </FadeIn>
      </div>

      <!-- Philosophy -->
      <div class="mb-12 lg:mb-16">
        {paragraphs.map((paragraph, index) => (
          <FadeIn client:visible delay={0.1 + index * 0.05}>
            <p class="text-lg md:text-xl text-gray-400 leading-relaxed text-center mb-6 last:mb-0">
              {paragraph}
            </p>
          </FadeIn>
        ))}

        {closingStatement && (
          <FadeIn client:visible delay={0.1 + paragraphs.length * 0.05}>
            <p class="text-lg md:text-xl text-white font-medium text-center mt-8">
              {closingStatement}
            </p>
          </FadeIn>
        )}
      </div>

      <!-- Values Grid -->
      {showValues && (
        <FadeIn client:visible delay={0.25}>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6 mb-12 lg:mb-16">
            {values.map((value) => (
              <div class="group text-center p-6 rounded-2xl bg-white/[0.02] border border-white/5 hover:border-white/10 hover:bg-white/[0.04] transition-all duration-fast">
                <div class="text-3xl mb-3 group-hover:scale-110 transition-transform duration-fast">
                  {value.icon}
                </div>
                <h3 class="font-medium text-white mb-1">{value.title}</h3>
                <p class="text-sm text-gray-500">{value.description}</p>
              </div>
            ))}
          </div>
        </FadeIn>
      )}

      <!-- Location -->
      {showLocation && (
        <FadeIn client:visible delay={0.3}>
          <div class="flex flex-col items-center justify-center gap-4">
            <!-- Map-like visual -->
            <div class="relative w-full max-w-md h-32 rounded-2xl overflow-hidden bg-gradient-to-br from-white/[0.02] to-transparent border border-white/5">
              <!-- Abstract map pattern -->
              <div class="absolute inset-0 opacity-30">
                <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.03)_1px,transparent_1px)] bg-[size:20px_20px]"></div>
              </div>

              <!-- Location pin -->
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="relative">
                  <div class="absolute inset-0 w-8 h-8 bg-accent/30 rounded-full animate-ping"></div>
                  <div class="relative w-8 h-8 bg-accent rounded-full flex items-center justify-center">
                    <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                    </svg>
                  </div>
                </div>
              </div>

              <!-- Decorative circles -->
              <div class="absolute top-4 right-4 w-16 h-16 border border-white/5 rounded-full"></div>
              <div class="absolute bottom-4 left-4 w-12 h-12 border border-white/5 rounded-full"></div>
            </div>

            <!-- Location text -->
            <div class="flex items-center gap-2 text-gray-400">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <span class="text-sm font-medium">{locationString}</span>
            </div>
          </div>
        </FadeIn>
      )}

      <!-- Additional content slot -->
      <slot />
    </div>
  </Container>
</section>

<style>
  /* Ping animation for location marker */
  @keyframes ping {
    75%, 100% {
      transform: scale(2);
      opacity: 0;
    }
  }

  .animate-ping {
    animation: ping 1.5s cubic-bezier(0, 0, 0.2, 1) infinite;
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .animate-ping {
      animation: none;
    }
  }
</style>

---
/**
 * Input Component
 *
 * Styled form input with label and error state support.
 *
 * Features:
 * - Text, email, password, etc. types
 * - Optional label
 * - Error state with message
 * - Icon support
 * - Focus ring styling
 */

interface Props {
  /** Input type */
  type?: 'text' | 'email' | 'password' | 'tel' | 'url' | 'number' | 'search';
  /** Input name (required for forms) */
  name: string;
  /** Input ID (defaults to name) */
  id?: string;
  /** Label text */
  label?: string;
  /** Placeholder text */
  placeholder?: string;
  /** Default value */
  value?: string;
  /** Required field */
  required?: boolean;
  /** Disabled state */
  disabled?: boolean;
  /** Error message */
  error?: string;
  /** Helper text */
  helperText?: string;
  /** Additional input classes */
  class?: string;
  /** Autocomplete attribute */
  autocomplete?: string;
}

const {
  type = 'text',
  name,
  id = name,
  label,
  placeholder,
  value,
  required = false,
  disabled = false,
  error,
  helperText,
  class: className = '',
  autocomplete,
} = Astro.props;

const hasError = !!error;
---

<div class="w-full">
  {label && (
    <label
      for={id}
      class="block text-sm font-medium text-gray-300 mb-2"
    >
      {label}
      {required && <span class="text-error ml-1">*</span>}
    </label>
  )}

  <div class="relative">
    <!-- Left icon slot -->
    <div class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 pointer-events-none">
      <slot name="icon-left" />
    </div>

    <input
      type={type}
      name={name}
      id={id}
      placeholder={placeholder}
      value={value}
      required={required}
      disabled={disabled}
      autocomplete={autocomplete}
      aria-invalid={hasError}
      aria-describedby={hasError ? `${id}-error` : helperText ? `${id}-helper` : undefined}
      class:list={[
        'w-full px-4 py-3 rounded-xl',
        'bg-white/5 border',
        'text-white placeholder:text-gray-500',
        'transition-all duration-fast',
        'focus:outline-none focus:ring-2 focus:ring-offset-0',
        hasError
          ? 'border-error/50 focus:border-error focus:ring-error/20'
          : 'border-white/10 focus:border-accent/50 focus:ring-accent/20',
        disabled && 'opacity-50 cursor-not-allowed',
        Astro.slots.has('icon-left') && 'pl-12',
        Astro.slots.has('icon-right') && 'pr-12',
        className,
      ]}
    />

    <!-- Right icon slot -->
    <div class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-500">
      <slot name="icon-right" />
    </div>
  </div>

  {/* Error message */}
  {error && (
    <p id={`${id}-error`} class="mt-2 text-sm text-error" role="alert">
      {error}
    </p>
  )}

  {/* Helper text */}
  {helperText && !error && (
    <p id={`${id}-helper`} class="mt-2 text-sm text-gray-500">
      {helperText}
    </p>
  )}
</div>

---
/**
 * Home Page
 *
 * Main landing page featuring:
 * - Hero section with animated elements
 * - Product showcase for SignScan (flagship)
 * - ToolWall — the full 30-tool catalog with the app's licensed icons
 * - Features grid (why SignScan)
 * - Coming soon section (AI Photo Editor)
 * - About section
 * - CTA section
 * - Footer with navigation and contact
 */

import Layout from '@layouts/Layout.astro';
import Header from '@components/common/Header.astro';
import Footer from '@components/common/Footer.astro';
import Hero from '@components/home/Hero.astro';
import ProductShowcase from '@components/home/ProductShowcase.astro';
import ToolWall from '@components/home/ToolWall.astro';
import Features from '@components/home/Features.astro';
import ComingSoon from '@components/home/ComingSoon.astro';
import About from '@components/home/About.astro';
import CTA from '@components/home/CTA.astro';
import SmoothScroll from '@components/animations/SmoothScroll';
---

<Layout>
  <SmoothScroll client:load>
    <Header />

    <!-- Hero Section -->
    <Hero
      badge="Introducing SignScan"
      headlineTop="Scan Anything."
      headlineBottom="Sign Everything."
      subtext="SignScan turns paper into signed, sealed, delivered — scan it, sign it, send it, all on your iPhone. Thirty professional document tools, every one of them running entirely on your device."
      primaryCta="Get SignScan"
      primaryCtaHref="#waitlist"
      secondaryCta="See the App"
      secondaryCtaHref="#products"
      phoneImage="/signscan-home.jpg"
      phoneAlt="SignScan Home screen with quick tools and recent documents"
    />

    <!-- Product Showcase: SignScan -->
    <ProductShowcase
      id="products"
      badge="Our Flagship Product"
      productName="SignScan"
      tagline="The scanner that signs"
      description="Most scanner apps stop at the PDF. SignScan is where the real work happens — sign the lease, fill the form, redact the account number, pull the receipt into a spreadsheet. Paper goes in; finished business comes out."
      features={[
        {
          icon: '/icons/tools/sign.svg',
          title: 'A Signature That Feels Real',
          description: 'Draw your signature once, then place it on anything — with ink that sits on the page like it was always there.',
        },
        {
          icon: '/icons/tools/recognizeText.svg',
          title: 'Reads Everything',
          description: 'Searchable scans, extracted text, tables to spreadsheets, receipts to CSV — even neat handwriting.',
        },
        {
          icon: '/icons/tools/redact.svg',
          title: 'True Redaction',
          description: 'Redact and blur actually remove the pixels. What you black out can never be copied back out.',
        },
        {
          icon: '/icons/site/lock.svg',
          title: 'Nothing Leaves Your Phone',
          description: 'Scanning, OCR, even translation run entirely on-device. No account, no cloud, no tracking.',
        },
      ]}
      ctaText="Get SignScan"
      ctaHref="#waitlist"
      secondaryCtaText="Browse the Tools"
      secondaryCtaHref="#tools"
      phoneImage="/signscan-tools.jpg"
      phoneAlt="SignScan Tools catalog — 30 tools, all on-device"
    />

    <!-- Tool Wall: the full 30-tool catalog -->
    <ToolWall />

    <!-- Features Grid: why SignScan -->
    <Features
      id="features"
      badge="Why SignScan"
      title="Built Like a Tool, Priced Like One"
      subtitle="No accounts. No cloud. No subscription treadmill — unless you want one."
      features={[
        {
          icon: '/icons/site/crown.svg',
          title: 'Pay Once, Own It',
          description: 'One purchase owns every tool, forever — $34.99, done. Prefer to rent? $4.99 a month, cancel anytime.',
          iconGradient: 'sign',
        },
        {
          icon: '/icons/site/lock.svg',
          title: 'Private by Design',
          description: 'Your documents never leave your iPhone. Every tool — OCR, translation, redaction — runs on-device.',
          iconGradient: 'capture',
        },
        {
          icon: '/icons/tools/scanID.svg',
          title: 'ID & Passport Mode',
          description: 'Both sides of a card on one true-size page. Print it at 100% and it matches the original, ruler-verified.',
          iconGradient: 'extract',
        },
        {
          icon: '/icons/tools/translate.svg',
          title: 'Offline Translation',
          description: 'Translate a scanned document with Apple’s on-device engine — in airplane mode, if you like.',
          iconGradient: 'organize',
        },
        {
          icon: '/icons/tools/watermark.svg',
          title: 'Paper-Grade Output',
          description: 'Watermarks, Bates numbering, headers and footers — vector-crisp stamps that survive print and export.',
          iconGradient: 'protect',
        },
        {
          icon: '/icons/site/magic.svg',
          title: 'Crafted, Not Assembled',
          description: 'A custom camera, a letterpress design language, and licensed illustration throughout. It feels like one object.',
          iconGradient: 'capture',
        },
      ]}
      columns={3}
      showBackground={true}
    />

    <!-- Coming Soon: AI Photo Editor -->
    <ComingSoon
      id="ai-photo-editor"
      badge="In the Lab"
      title="AI Photo Editor"
      description="Professional-grade photo editing powered by cutting-edge AI. Transform your selfies and portraits with a single tap."
      emailPlaceholder="Enter your email"
      buttonText="Notify Me"
      formName="ai-editor-waitlist"
      privacyNote="Be the first to know when we launch. No spam, ever."
      accentColor="violet"
    />

    <!-- About Section -->
    <About
      closingStatement="SignScan is our flagship. It won't be our last."
    />

    <!-- CTA Section -->
    <CTA
      headline="Be First in Line"
      description="SignScan is putting the finishing touches on its App Store debut. Leave your email and we'll tell you the moment it lands — nothing else, ever."
      buttonText="Notify Me"
    />

    <!-- Footer -->
    <Footer />

  </SmoothScroll>
</Layout>

---
/**
 * Product Showcase Component
 *
 * Highlights Cyclia with a phone mockup and feature list.
 * Designed to create desire and drive waitlist signups.
 *
 * Layout:
 * - Desktop: Phone left, content right
 * - Mobile: Content top, phone bottom (for better messaging)
 */

import Container from '@components/ui/Container.astro';
import Button from '@components/ui/Button.astro';
import Badge from '@components/ui/Badge.astro';
import FadeIn from '@components/animations/FadeIn';
import PhoneMockup from '@components/ui/PhoneMockup';

interface Feature {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  /** Section badge text */
  badge?: string;
  /** Product name */
  productName?: string;
  /** Product tagline */
  tagline?: string;
  /** Product description */
  description?: string;
  /** Feature list */
  features?: Feature[];
  /** CTA button text */
  ctaText?: string;
  /** CTA button link */
  ctaHref?: string;
  /** Secondary CTA text */
  secondaryCtaText?: string;
  /** Secondary CTA link */
  secondaryCtaHref?: string;
  /** Phone mockup image */
  phoneImage?: string;
  /** Phone mockup alt text */
  phoneAlt?: string;
  /** Section ID for navigation */
  id?: string;
}

const {
  badge = 'Our Flagship Product',
  productName = 'Cyclia',
  tagline = 'Your Daily Companion for Mindful Living',
  description = 'Cyclia helps you build better habits, track your progress, and stay focused on what matters most. Designed with intention, built for your life.',
  features = [
    {
      icon: '📊',
      title: 'Smart Insights',
      description: 'Understand your patterns with beautiful analytics that actually make sense.',
    },
    {
      icon: '🎯',
      title: 'Goal Tracking',
      description: 'Set meaningful goals and watch your progress unfold day by day.',
    },
    {
      icon: '🔔',
      title: 'Gentle Reminders',
      description: 'Stay on track with notifications that respect your time and attention.',
    },
    {
      icon: '🔒',
      title: 'Privacy First',
      description: 'Your data stays on your device. No accounts required, no tracking.',
    },
  ],
  ctaText = 'Join the Waitlist',
  ctaHref = '#waitlist',
  secondaryCtaText = 'Learn More',
  secondaryCtaHref = '#features',
  phoneImage = '',
  phoneAlt = 'Cyclia app interface',
  id = 'products',
} = Astro.props;
---

<section id={id} class="section relative overflow-hidden" aria-labelledby="product-title">
  <!-- Subtle background gradient -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-1/2 left-0 -translate-y-1/2 w-[600px] h-[600px] bg-accent/5 rounded-full blur-[150px]"></div>
  </div>

  <Container size="wide" class="relative">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <!-- Phone Mockup -->
      <div class="order-2 lg:order-1 flex justify-center">
        <FadeIn client:visible direction="left">
          <PhoneMockup
            client:visible
            imageSrc={phoneImage}
            alt={phoneAlt}
            className="w-[280px] md:w-[320px] lg:w-[340px]"
          />
        </FadeIn>
      </div>

      <!-- Content -->
      <div class="order-1 lg:order-2">
        <!-- Badge -->
        <FadeIn client:visible delay={0}>
          <Badge variant="accent" class="mb-4">
            {badge}
          </Badge>
        </FadeIn>

        <!-- Product Name -->
        <FadeIn client:visible delay={0.05}>
          <h2 id="product-title" class="h1 mb-3">
            {productName}
          </h2>
        </FadeIn>

        <!-- Tagline -->
        <FadeIn client:visible delay={0.1}>
          <p class="text-xl md:text-2xl text-accent-light font-display font-medium mb-6">
            {tagline}
          </p>
        </FadeIn>

        <!-- Description -->
        <FadeIn client:visible delay={0.15}>
          <p class="text-gray-400 text-lg leading-relaxed mb-8">
            {description}
          </p>
        </FadeIn>

        <!-- Features List -->
        <div class="space-y-4 mb-10">
          {features.map((feature, index) => (
            <FadeIn client:visible delay={0.2 + index * 0.05}>
              <div class="flex items-start gap-4 p-4 rounded-2xl bg-white/[0.02] border border-white/5 hover:border-white/10 hover:bg-white/[0.04] transition-all duration-fast group">
                <div class="w-10 h-10 rounded-xl bg-accent/10 border border-accent/20 flex items-center justify-center shrink-0 group-hover:bg-accent/20 transition-colors duration-fast">
                  {feature.icon.endsWith('.svg') ? (
                    <img src={feature.icon} alt="" class="w-5 h-5" loading="lazy" aria-hidden="true" />
                  ) : (
                    <span class="text-lg">{feature.icon}</span>
                  )}
                </div>
                <div>
                  <h3 class="font-medium text-white mb-1">{feature.title}</h3>
                  <p class="text-sm text-gray-400">{feature.description}</p>
                </div>
              </div>
            </FadeIn>
          ))}
        </div>

        <!-- CTAs -->
        <FadeIn client:visible delay={0.4}>
          <div class="flex flex-col sm:flex-row gap-4">
            <Button href={ctaHref} size="lg">
              {ctaText}
              <svg
                slot="icon-right"
                class="w-4 h-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"
                />
              </svg>
            </Button>
            {secondaryCtaText && (
              <Button href={secondaryCtaHref} variant="ghost" size="lg">
                {secondaryCtaText}
              </Button>
            )}
          </div>
        </FadeIn>

        <!-- App Store badges placeholder -->
        <FadeIn client:visible delay={0.45}>
          <div class="mt-8 flex items-center gap-4 text-sm text-gray-500">
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
              </svg>
              <span>iOS Coming Soon</span>
            </div>
            <div class="w-px h-4 bg-gray-700"></div>
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.198l2.807 1.626a1 1 0 0 1 0 1.73l-2.808 1.626L15.206 12l2.492-2.491zM5.864 2.658L16.802 8.99l-2.303 2.303-8.635-8.635z"/>
              </svg>
              <span>Android Coming Soon</span>
            </div>
          </div>
        </FadeIn>
      </div>
    </div>
  </Container>
</section>

<style>
  /* Feature card subtle hover lift */
  .group:hover {
    transform: translateY(-2px);
  }
</style>

---
/**
 * Footer Component
 *
 * Site-wide footer with navigation, contact info, and legal.
 *
 * Features:
 * - Brand identity
 * - Navigation links
 * - Contact information
 * - Social media links
 * - Legal links & copyright
 * - Back to top button
 * - Responsive grid layout
 */

import Container from '@components/ui/Container.astro';
import { siteConfig } from '@lib/config';

interface Props {
  /** Show back to top button */
  showBackToTop?: boolean;
}

const { showBackToTop = true } = Astro.props;

// Navigation links
const navLinks = [
  { label: 'Products', href: '#products' },
  { label: 'Features', href: '#features' },
  { label: 'About', href: '#about' },
  { label: 'Contact', href: '#waitlist' },
];

// Product links
const productLinks = [
  { label: 'Cyclia', href: '#products' },
  { label: 'AI Photo Editor', href: '#ai-photo-editor', badge: 'Soon' },
];

// Legal links
const legalLinks = [
  { label: 'Privacy Policy', href: '/privacy' },
  { label: 'Terms of Service', href: '/terms' },
];

// Social links with icons
const socialLinks = [
  {
    name: 'Twitter',
    href: siteConfig.social.twitter ? `https://twitter.com/${siteConfig.social.twitter}` : null,
    icon: `<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>`,
  },
  {
    name: 'LinkedIn',
    href: siteConfig.social.linkedin ? `https://linkedin.com/company/${siteConfig.social.linkedin}` : null,
    icon: `<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>`,
  },
  {
    name: 'Instagram',
    href: siteConfig.social.instagram ? `https://instagram.com/${siteConfig.social.instagram}` : null,
    icon: `<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>`,
  },
  {
    name: 'GitHub',
    href: siteConfig.social.github ? `https://github.com/${siteConfig.social.github}` : null,
    icon: `<path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>`,
  },
].filter(link => link.href);

const currentYear = new Date().getFullYear();
const { name, email, phone, address } = siteConfig;
---

<footer class="relative bg-black border-t border-white/5" role="contentinfo">
  <!-- Background subtle gradient -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-accent/5 rounded-full blur-[150px]"></div>
  </div>

  <Container class="relative">
    <!-- Main Footer Content -->
    <div class="py-12 lg:py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">
        <!-- Brand Column -->
        <div class="lg:col-span-1">
          <!-- Logo -->
          <a
            href="/"
            class="inline-flex items-center gap-2 text-white font-display font-bold text-xl mb-4 hover:text-accent-light transition-colors duration-fast"
            aria-label={`${name} - Home`}
          >
            <span class="w-8 h-8 rounded-lg bg-gradient-to-br from-accent to-accent-dark flex items-center justify-center text-white text-sm font-bold">
              S
            </span>
            <span>{name}</span>
          </a>

          <p class="text-gray-500 text-sm leading-relaxed mb-6 max-w-xs">
            Crafting thoughtful mobile experiences that people love. Based in Sacramento, California.
          </p>

          <!-- Social Links -->
          {socialLinks.length > 0 && (
            <div class="flex items-center gap-3">
              {socialLinks.map((social) => (
                <a
                  href={social.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="w-9 h-9 rounded-lg bg-white/5 border border-white/5 flex items-center justify-center text-gray-500 hover:text-white hover:bg-white/10 hover:border-white/10 transition-all duration-fast"
                  aria-label={`Follow us on ${social.name}`}
                >
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true" set:html={social.icon} />
                </a>
              ))}
            </div>
          )}
        </div>

        <!-- Navigation Column -->
        <div>
          <h3 class="text-white font-medium mb-4">Navigation</h3>
          <ul class="space-y-3">
            {navLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-gray-500 hover:text-white transition-colors duration-fast text-sm"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Products Column -->
        <div>
          <h3 class="text-white font-medium mb-4">Products</h3>
          <ul class="space-y-3">
            {productLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="inline-flex items-center gap-2 text-gray-500 hover:text-white transition-colors duration-fast text-sm"
                >
                  {link.label}
                  {link.badge && (
                    <span class="px-1.5 py-0.5 text-[10px] font-medium uppercase tracking-wider bg-accent/20 text-accent-light rounded">
                      {link.badge}
                    </span>
                  )}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Contact Column -->
        <div>
          <h3 class="text-white font-medium mb-4">Contact</h3>
          <ul class="space-y-3">
            <li>
              <a
                href={`mailto:${email}`}
                class="inline-flex items-center gap-2 text-gray-500 hover:text-white transition-colors duration-fast text-sm group"
              >
                <svg class="w-4 h-4 text-gray-600 group-hover:text-accent-light transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <span>{email}</span>
              </a>
            </li>
            <li>
              <a
                href={`tel:${phone.replace(/[^+\d]/g, '')}`}
                class="inline-flex items-center gap-2 text-gray-500 hover:text-white transition-colors duration-fast text-sm group"
              >
                <svg class="w-4 h-4 text-gray-600 group-hover:text-accent-light transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                <span>{phone}</span>
              </a>
            </li>
            <li class="flex items-start gap-2 text-gray-500 text-sm">
              <svg class="w-4 h-4 text-gray-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <span>
                {address.city}, {address.state}
              </span>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="py-6 border-t border-white/5">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <!-- Copyright -->
        <p class="text-gray-600 text-sm">
          &copy; {currentYear} {name}. All rights reserved.
        </p>

        <!-- Legal Links -->
        <div class="flex items-center gap-6">
          {legalLinks.map((link) => (
            <a
              href={link.href}
              class="text-gray-600 hover:text-gray-400 transition-colors duration-fast text-sm"
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </Container>

  <!-- Back to Top Button -->
  {showBackToTop && (
    <button
      id="back-to-top"
      class="fixed bottom-6 right-6 w-10 h-10 rounded-full bg-white/10 border border-white/10 flex items-center justify-center text-gray-400 hover:text-white hover:bg-white/20 transition-all duration-fast opacity-0 invisible translate-y-4 z-40"
      aria-label="Back to top"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
      </svg>
    </button>
  )}
</footer>

<script>
  // Back to top functionality
  const backToTopButton = document.getElementById('back-to-top');

  if (backToTopButton) {
    // Show/hide based on scroll position
    const toggleVisibility = () => {
      if (window.scrollY > 500) {
        backToTopButton.classList.remove('opacity-0', 'invisible', 'translate-y-4');
        backToTopButton.classList.add('opacity-100', 'visible', 'translate-y-0');
      } else {
        backToTopButton.classList.add('opacity-0', 'invisible', 'translate-y-4');
        backToTopButton.classList.remove('opacity-100', 'visible', 'translate-y-0');
      }
    };

    // Scroll to top on click
    backToTopButton.addEventListener('click', () => {
      window.scrollTo({
        top: 0,
        behavior: 'smooth',
      });
    });

    // Listen for scroll events
    window.addEventListener('scroll', toggleVisibility, { passive: true });

    // Initial check
    toggleVisibility();
  }
</script>

<style>
  /* Smooth transition for back to top button */
  #back-to-top {
    transition: opacity 0.3s ease, visibility 0.3s ease, transform 0.3s ease, background-color 0.15s ease;
  }
</style>
